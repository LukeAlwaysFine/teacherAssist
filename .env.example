# ═══════════════════════════════════════════════════
# 教师助手 — 环境配置文件
# 复制此文件为 .env 并填入你的配置
#   cp .env.example .env
# ═══════════════════════════════════════════════════

# ─── 应用基础 ───
PROJECT_NAME=teacherAssist
DEBUG=false

# ─── 数据库 ───
# 本地开发: sqlite+aiosqlite:///./teacher_assist.db
# 生产环境: postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL=sqlite+aiosqlite:///./data/teacher_assist.db

# ─── JWT 安全（生产环境务必修改！） ───
# 用以下命令生成随机密钥: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=<your-random-secret-key-here>
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── AI 大模型（必填） ───
# 当前默认使用 DeepSeek，如需切换为 Claude 修改 LLM_PROVIDER
LLM_PROVIDER=deepseek
LLM_DEFAULT_MAX_TOKENS=4096

# DeepSeek（获取 Key: https://platform.deepseek.com/api_keys）
DEEPSEEK_API_KEY=<your-deepseek-api-key>
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_MAX_TOKENS=4096
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Anthropic Claude（备选，获取 Key: https://console.anthropic.com/）
ANTHROPIC_API_KEY=<your-anthropic-api-key>
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=4096

# ─── 语音识别（可选） ───
# OpenAI Whisper API — 云端转写，需 OpenAI API Key
# 留空则使用本地 Whisper.cpp CPU 引擎
OPENAI_API_KEY=
WHISPER_MODEL=whisper-1

# ─── CORS 跨域 ───
# Docker 本地使用默认即可；部署到服务器时改为实际域名
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
